{
  "name": "livkndt-personal-web",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "prepare": "husky",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,astro,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,astro,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "migrate:posts": "tsx scripts/migrate-posts.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.3",
    "@astrojs/rss": "^4.0.5",
    "@astrojs/sitemap": "^3.2.2",
    "@astrojs/tailwind": "^5.1.3",
    "astro": "^5.16.4",
    "date-fns": "^3.6.0",
    "gray-matter": "^4.0.3",
    "tailwindcss": "^3.4.13"
  },
  "devDependencies": {
    "@astrojs/react": "^3.6.2",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^1.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.0.15"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,astro,md,json}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
