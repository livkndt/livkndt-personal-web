---
import { siteConfig } from '../config';
import Navigation from './Navigation.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header
  class="sticky top-0 z-50 bg-eggshell/80 dark:bg-twilight-indigo/80 backdrop-blur-md border-b border-muted-teal/30 dark:border-muted-teal/20"
>
  <nav class="container mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16">
      <a
        href="/"
        class="text-xl font-bold text-burnt-peach dark:text-eggshell hover:text-burnt-peach dark:hover:text-muted-teal transition-colors focus:outline-none focus:ring-2 focus:ring-burnt-peach dark:focus:ring-muted-teal focus:ring-offset-2 dark:focus:ring-offset-twilight-indigo rounded"
        aria-label="Home"
      >
        {siteConfig.author}
      </a>
      <div class="flex items-center gap-4">
        <Navigation />
        <ThemeToggle />
      </div>
    </div>
  </nav>
</header>
