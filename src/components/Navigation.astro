---
import { siteConfig } from '../config';

interface Props {
  mobile?: boolean;
}

const { mobile = false } = Astro.props;
const currentPath = Astro.url.pathname;
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'Portfolio' },
  { href: '/experience', label: 'Experience' },
  // Conditionally add Projects if feature flag is enabled
  ...(siteConfig.features.projects ? [{ href: '/projects', label: 'Projects' }] : []),
  { href: '/archive', label: 'Archive' },
];

const isActive = (href: string) => {
  if (href === '/') {
    return currentPath === '/';
  }
  return currentPath.startsWith(href);
};
---

<nav aria-label="Main navigation">
  <ul class={mobile ? 'flex flex-col gap-4' : 'flex items-center gap-6'}>
    {
      navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class={`text-sm font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-burnt-peach dark:focus:ring-muted-teal focus:ring-offset-2 dark:focus:ring-offset-twilight-indigo rounded px-2 py-1 ${
              mobile ? 'block py-2' : ''
            } ${
              isActive(item.href)
                ? 'text-twilight-indigo dark:text-eggshell bg-burnt-peach/20 dark:bg-muted-teal/30 ring-1 ring-burnt-peach/40 dark:ring-muted-teal/50'
                : 'text-twilight-indigo/70 dark:text-eggshell/80 hover:text-twilight-indigo dark:hover:text-eggshell hover:bg-apricot-cream/30 dark:hover:bg-muted-teal/20'
            }`}
            aria-current={isActive(item.href) ? 'page' : undefined}
            data-mobile-link={mobile ? 'true' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
