---
const currentPath = Astro.url.pathname;
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/experience', label: 'Experience' },
  { href: '/blog', label: 'Blog' },
];

const isActive = (href: string) => {
  if (href === '/') {
    return currentPath === '/';
  }
  return currentPath.startsWith(href);
};
---

<nav aria-label="Main navigation">
  <ul class="flex items-center gap-6">
    {navItems.map((item) => (
      <li>
        <a
          href={item.href}
          class={`text-sm font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-carrot-orange dark:focus:ring-dry-sage focus:ring-offset-2 dark:focus:ring-offset-olive rounded px-2 py-1 ${
            isActive(item.href)
              ? 'text-carrot-orange dark:text-dry-sage'
              : 'text-olive dark:text-peach-fuzz/80 hover:text-carrot-orange dark:hover:text-dry-sage'
          }`}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

