---
interface Props {
  mobile?: boolean;
}

const { mobile = false } = Astro.props;
const currentPath = Astro.url.pathname;
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/experience', label: 'Experience' },
  { href: '/blog', label: 'Blog' },
];

const isActive = (href: string) => {
  if (href === '/') {
    return currentPath === '/';
  }
  return currentPath.startsWith(href);
};
---

<nav aria-label="Main navigation">
  <ul class={mobile ? 'flex flex-col gap-4' : 'flex items-center gap-6'}>
    {
      navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class={`text-sm font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-burnt-peach dark:focus:ring-muted-teal focus:ring-offset-2 dark:focus:ring-offset-twilight-indigo rounded px-2 py-1 ${
              mobile ? 'block py-2' : ''
            } ${
              isActive(item.href)
                ? 'text-burnt-peach dark:text-muted-teal'
                : 'text-burnt-peach dark:text-eggshell/80 hover:text-burnt-peach dark:hover:text-muted-teal'
            }`}
            aria-current={isActive(item.href) ? 'page' : undefined}
            data-mobile-link={mobile ? 'true' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
