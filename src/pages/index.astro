---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';
---

<BaseLayout
  title={siteConfig.title}
  description={siteConfig.description}
  showHeader={false}
  centerContent={true}
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14 lg:py-20">
    <div class="max-w-4xl mx-auto flex flex-col lg:flex-row lg:items-center lg:gap-16">
      <!-- Left: identity -->
      <div class="text-center lg:flex-shrink-0 lg:w-64 mb-10 lg:mb-0">
        <div
          class="w-32 h-32 sm:w-36 sm:h-36 rounded-full overflow-hidden shadow-lg border-4 border-apricot-cream/50 dark:border-apricot-cream/30 mx-auto mb-5"
        >
          <img
            src="https://d19w7e3j8gkywb.cloudfront.net/olivia-2022.webp"
            alt="Olivia Knoedt"
            class="w-full h-full object-cover scale-150 object-middle"
            width="144"
            height="144"
            loading="eager"
          />
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold mb-3 text-twilight-indigo dark:text-eggshell">
          Olivia Knoedt
        </h1>
        <p class="text-base text-twilight-indigo/70 dark:text-eggshell/70 leading-relaxed">
          Maker of things, digital, humanoid and woolly. Based in London.
        </p>
      </div>

      <!-- Right: links -->
      <nav aria-label="Site sections" class="flex-1">
        <ul class="flex flex-col gap-3">
          <li>
            <a
              href="/about"
              class="group flex items-center justify-between w-full px-6 py-4 bg-eggshell dark:bg-twilight-indigo/50 border border-apricot-cream/40 dark:border-muted-teal/20 rounded-xl hover:border-burnt-peach/60 dark:hover:border-muted-teal/60 hover:shadow-md transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-burnt-peach dark:focus:ring-muted-teal focus:ring-offset-2 dark:focus:ring-offset-twilight-indigo"
            >
              <span class="font-semibold text-twilight-indigo dark:text-eggshell"
                >Tech Portfolio</span
              >
              <span
                class="text-twilight-indigo/40 dark:text-eggshell/40 group-hover:text-burnt-peach dark:group-hover:text-muted-teal transition-colors text-lg"
                aria-hidden="true">→</span
              >
            </a>
          </li>
          <li>
            <a
              href={siteConfig.social.substackTech}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center justify-between w-full px-6 py-4 bg-eggshell dark:bg-twilight-indigo/50 border border-apricot-cream/40 dark:border-muted-teal/20 rounded-xl hover:border-burnt-peach/60 dark:hover:border-muted-teal/60 hover:shadow-md transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-burnt-peach dark:focus:ring-muted-teal focus:ring-offset-2 dark:focus:ring-offset-twilight-indigo"
            >
              <div class="text-left">
                <span class="font-semibold text-twilight-indigo dark:text-eggshell block"
                  >Balancing the Stack</span
                >
                <span class="text-sm text-twilight-indigo/50 dark:text-eggshell/50"
                  >on Substack</span
                >
              </div>
              <span
                class="text-twilight-indigo/40 dark:text-eggshell/40 group-hover:text-burnt-peach dark:group-hover:text-muted-teal transition-colors text-lg"
                aria-hidden="true">↗</span
              >
            </a>
          </li>
          <li>
            <a
              href={siteConfig.social.substackMakes}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center justify-between w-full px-6 py-4 bg-eggshell dark:bg-twilight-indigo/50 border border-apricot-cream/40 dark:border-muted-teal/20 rounded-xl hover:border-burnt-peach/60 dark:hover:border-muted-teal/60 hover:shadow-md transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-burnt-peach dark:focus:ring-muted-teal focus:ring-offset-2 dark:focus:ring-offset-twilight-indigo"
            >
              <div class="text-left">
                <span class="font-semibold text-twilight-indigo dark:text-eggshell block"
                  >Olive's Makes</span
                >
                <span class="text-sm text-twilight-indigo/50 dark:text-eggshell/50"
                  >on Substack</span
                >
              </div>
              <span
                class="text-twilight-indigo/40 dark:text-eggshell/40 group-hover:text-burnt-peach dark:group-hover:text-muted-teal transition-colors text-lg"
                aria-hidden="true">↗</span
              >
            </a>
          </li>
          <li>
            <a
              href={siteConfig.social.ravelry}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center justify-between w-full px-6 py-4 bg-eggshell dark:bg-twilight-indigo/50 border border-apricot-cream/40 dark:border-muted-teal/20 rounded-xl hover:border-burnt-peach/60 dark:hover:border-muted-teal/60 hover:shadow-md transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-burnt-peach dark:focus:ring-muted-teal focus:ring-offset-2 dark:focus:ring-offset-twilight-indigo"
            >
              <div class="text-left">
                <span class="font-semibold text-twilight-indigo dark:text-eggshell block"
                  >Ravelry</span
                >
                <span class="text-sm text-twilight-indigo/50 dark:text-eggshell/50"
                  >Fibre projects</span
                >
              </div>
              <span
                class="text-twilight-indigo/40 dark:text-eggshell/40 group-hover:text-burnt-peach dark:group-hover:text-muted-teal transition-colors text-lg"
                aria-hidden="true">↗</span
              >
            </a>
          </li>
          <li>
            <a
              href={siteConfig.social.threadloop}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center justify-between w-full px-6 py-4 bg-eggshell dark:bg-twilight-indigo/50 border border-apricot-cream/40 dark:border-muted-teal/20 rounded-xl hover:border-burnt-peach/60 dark:hover:border-muted-teal/60 hover:shadow-md transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-burnt-peach dark:focus:ring-muted-teal focus:ring-offset-2 dark:focus:ring-offset-twilight-indigo"
            >
              <div class="text-left">
                <span class="font-semibold text-twilight-indigo dark:text-eggshell block"
                  >Threadloop</span
                >
                <span class="text-sm text-twilight-indigo/50 dark:text-eggshell/50"
                  >Sewing projects</span
                >
              </div>
              <span
                class="text-twilight-indigo/40 dark:text-eggshell/40 group-hover:text-burnt-peach dark:group-hover:text-muted-teal transition-colors text-lg"
                aria-hidden="true">↗</span
              >
            </a>
          </li>
          <li>
            <a
              href="/archive"
              class="group flex items-center justify-between w-full px-6 py-4 bg-eggshell dark:bg-twilight-indigo/50 border border-apricot-cream/40 dark:border-muted-teal/20 rounded-xl hover:border-burnt-peach/60 dark:hover:border-muted-teal/60 hover:shadow-md transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-burnt-peach dark:focus:ring-muted-teal focus:ring-offset-2 dark:focus:ring-offset-twilight-indigo"
            >
              <div class="text-left">
                <span class="font-semibold text-twilight-indigo dark:text-eggshell block"
                  >Archive</span
                >
                <span class="text-sm text-twilight-indigo/50 dark:text-eggshell/50"
                  >Older writing</span
                >
              </div>
              <span
                class="text-twilight-indigo/40 dark:text-eggshell/40 group-hover:text-burnt-peach dark:group-hover:text-muted-teal transition-colors text-lg"
                aria-hidden="true">→</span
              >
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</BaseLayout>
