---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../../config';
import { format } from 'date-fns';

const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const posts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title={`Archive | ${siteConfig.title}`}
  description="Older writing on software engineering, technology, and more."
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-20">
    <div class="max-w-4xl mx-auto">
      <div class="mb-12">
        <h1 class="text-4xl sm:text-5xl font-bold mb-4 text-twilight-indigo dark:text-eggshell">
          Archive
        </h1>
        <p class="text-lg text-twilight-indigo/60 dark:text-eggshell/60">
          Older writing. New posts are on <a
            href={siteConfig.social.substackTech}
            target="_blank"
            rel="noopener noreferrer"
            class="text-burnt-peach dark:text-muted-teal hover:underline">Substack</a
          >.
        </p>
        <iframe
          src="https://balancingthestack.substack.com/embed"
          width="480"
          height="320"
          style="margin: 1rem auto 0 auto;"
          title="Subscribe to Balancing the Stack on Substack"></iframe>
      </div>
      {
        posts.length === 0 ? (
          <p class="text-lg text-twilight-indigo/70 dark:text-eggshell/70">Nothing here yet.</p>
        ) : (
          <ul class="space-y-8">
            {posts.map((post) => (
              <li>
                <article class="border-b border-apricot-cream/30 dark:border-apricot-cream/20 pb-8 last:border-0">
                  <h2 class="text-2xl sm:text-3xl font-bold mb-3">
                    <a
                      href={`/blog/${post.slug}`}
                      class="text-twilight-indigo dark:text-eggshell hover:text-burnt-peach dark:hover:text-muted-teal transition-colors focus:outline-none focus:ring-2 focus:ring-burnt-peach dark:focus:ring-muted-teal focus:ring-offset-2 dark:focus:ring-offset-twilight-indigo rounded"
                    >
                      {post.data.title}
                    </a>
                  </h2>
                  <p class="text-twilight-indigo/70 dark:text-eggshell/70 mb-4">
                    {post.data.description}
                  </p>
                  <div class="flex flex-wrap items-center gap-4 text-sm text-twilight-indigo/60 dark:text-eggshell/60">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {format(post.data.pubDate, 'd MMMM yyyy')}
                    </time>
                    {post.data.tags.length > 0 && (
                      <>
                        <span>•</span>
                        <ul class="flex flex-wrap gap-2">
                          {post.data.tags.map((tag) => (
                            <li>
                              <span class="px-2 py-1 bg-apricot-cream/30 dark:bg-apricot-cream/20 text-twilight-indigo dark:text-eggshell rounded text-xs">
                                {tag}
                              </span>
                            </li>
                          ))}
                        </ul>
                      </>
                    )}
                  </div>
                </article>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </div>
</BaseLayout>
